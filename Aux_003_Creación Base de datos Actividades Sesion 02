= {p: np.random.randint(1_000_000, 80_000_000) for p in paises}\n","\n","def poblacion_con_crecimiento(fila):\n","    base = base_poblacion[fila[\"pais\"]]\n","    # 1.2 % de crecimiento anual\n","    factor = 1 + 0.012 * (fila[\"anio\"] - 2020)\n","    return base * factor\n","\n","df[\"poblacion\"] = df.apply(poblacion_con_crecimiento, axis=1)\n","\n","# 4. Tasas de empleo / desempleo / inactividad\n","df[\"tasa_desempleo\"] = rng.uniform(3, 18, size=len(df))      # en %\n","df[\"tasa_inactividad\"] = rng.uniform(5, 25, size=len(df))    # en %\n","df[\"tasa_empleo\"] = 100 - df[\"tasa_desempleo\"] - df[\"tasa_inactividad\"]\n","\n","# 5. PEA, ocupados y desocupados (en número de personas)\n","df[\"poblacion_economicamente_activa\"] = df[\"poblacion\"] * (1 - df[\"tasa_inactividad\"] / 100)\n","df[\"ocupados\"] = df[\"poblacion_economicamente_activa\"] * (1 - df[\"tasa_desempleo\"] / 100)\n","df[\"desocupados\"] = df[\"poblacion_economicamente_activa\"] - df[\"ocupados\"]\n","\n","# 6. PIB per cápita y PIB total\n","#    niveles entre 3 mil y 50 mil, con leve tendencia creciente\n","df[\"pib_pc\"] = rng.uniform(3_000, 50_000, size=len(df)) * (1 + 0.02 * (df[\"anio\"] - 2020))\n","df[\"PIB\"] = df[\"poblacion\"] * df[\"pib_pc\"]\n","\n","# 7. Redondear algunas variables para que se vean más \"limpias\"\n","cols_enteras = [\n","    \"area_km2\", \"poblacion\", \"poblacion_economicamente_activa\",\n","    \"ocupados\", \"desocupados\", \"pib_pc\", \"PIB\"\n","]\n","\n","df[cols_enteras] = df[cols_enteras].round(0).astype(\"int64\")\n","\n","df.head()\n"]},{"cell_type":"code","source":["df.to_csv(\"pib_9paises_2020_2022.csv\", index=False)\n","df.to_excel(\"pib_9paises_2020_2022.xlsx\", index=False)\n","df.to_stata(\"pib_9paises_2020_2022.dta\", write_index=False)\n","\n","\n"],"metadata":{"id":"CN1IV4ee7cvo"},"execution_count":null,"outputs":[]}]}